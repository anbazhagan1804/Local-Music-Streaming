# Copy this file to .env and adjust values for your home server.
NODE_ENV=production
HOST=0.0.0.0
PORT=4000

# REQUIRED: change this to a strong random string in production
JWT_SECRET=change-me-to-a-long-random-secret

# Optional API behavior
CORS_ORIGIN=http://localhost:8080
ALLOW_REGISTRATION=true
BCRYPT_ROUNDS=12

# Initial admin account (created on first startup if not found)
ADMIN_EMAIL=admin@local
ADMIN_PASSWORD=change-me-now

# Host path to your music library; used by docker-compose volume mount
MUSIC_LIBRARY_HOST_PATH=D:/Media/Music

# Internal container paths (normally leave as-is)
DATA_DIR=/data
MUSIC_DIR=/music
